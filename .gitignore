*.bin
hub/

# Jupyter checkpoints
.ipynb_checkpoints/

# OS/editor
.DS_Store
.idea/
.vscode/

# Secrets / credentials — never commit
*.env
.env
secrets.*

# Internal agent working notes — not for public consumption
AGENT_NOTES.md

# Analysis CSVs with absolute machine paths
reports/**/*.csv

# tex generation — LaTeX build artifacts (sources live under tex/report and tex/poster)
tex/**/*.aux
tex/**/*.bbl
tex/**/*.bcf
tex/**/*.blg
tex/**/*.fdb_latexmk
tex/**/*.fls
tex/**/*.log
tex/**/*.out
tex/**/*.run.xml
tex/**/*.synctex.gz
tex/**/*.nav
tex/**/*.snm
tex/**/*.toc
tex/**/*.xdv

# Compiled PDFs are built in-tree but published to the repo root by CI
tex/report/main.pdf
tex/poster/main.pdf
tex/poster/out_cmyk*.pdf

# CMYK colour profiles — large binaries, used locally by tex/poster/do_cmyk.sh
tex/poster/ECI_Offset_2009/
